{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "securetag-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3100,
      "autoPort": false
    },
    {
      "name": "securetag-prod",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3100,
      "autoPort": false
    },
    {
      "name": "securetag-preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "start", "-p", "3210"],
      "port": 3210,
      "autoPort": true
    }
  ]
}
