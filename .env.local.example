# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL used for QR codes + email links (must match where the app runs).
NEXT_PUBLIC_BASE_URL=http://localhost:3100

# --- Email alerts (optional) ---
# Owner gets an email when someone scans their tag. Uses Resend (resend.com).
# Leave blank to disable email (in-app realtime still works).
RESEND_API_KEY=
EMAIL_FROM=SecureTag <onboarding@resend.dev>

# NOTE: There is NO admin email/password here. Admins are a role in the
# `profiles` table. Seed your first admin once via supabase-schema.sql.
