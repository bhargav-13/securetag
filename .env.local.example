# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL used for QR codes + email links (must match where the app runs).
NEXT_PUBLIC_BASE_URL=http://localhost:3100

# --- Email alerts ---
# Option A (recommended, free, no domain): SMTP (Gmail App Password / Brevo).
#   Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=465 SMTP_USER=you@gmail.com SMTP_PASS=<app password>
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# Option B: Resend REST (needs a verified domain to email arbitrary owners).
RESEND_API_KEY=

# --- WhatsApp alerts (Meta WhatsApp Cloud API) ---
# Meta > WhatsApp > API Setup. Blank = disabled.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Cold notifications need an approved template; blank = plain text (24h window only).
WHATSAPP_TEMPLATE=
WHATSAPP_TEMPLATE_LANG=en

# NOTE: There is NO admin email/password here. Admins are a role in the
# `profiles` table. Seed your first admin once via supabase-schema.sql.
